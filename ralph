#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
CONFIG_DIR="${RALPH_CONFIG_DIR:-$HOME/.config/ralph}"

# Default cap for plan mode (build mode calculates from the plan)
PLAN_DEFAULT_CAP=3

ARTIFACTS=(IMPLEMENTATION_PLAN.md PROGRESS.md PROMPT_plan.md PROMPT_build.md)
ARCHIVE_DIR=".ralph"

# --- Backend definitions ---
# Each backend_<name> function sets well-known variables and defines
# build_backend_cmd(model) which populates the BACKEND_CMD array.
# Adding a new backend only requires a new function and a SUPPORTED_BACKENDS entry.

SUPPORTED_BACKENDS=(claude codex copilot)

# shellcheck disable=SC2034  # Variables are set here and consumed in cmd_loop
backend_claude() {
    BACKEND_NAME="claude"
    BACKEND_CLI="claude"
    BACKEND_DEFAULT_MODEL="opus"
    BACKEND_PERMISSION_FLAG="--dangerously-skip-permissions"
    BACKEND_PERMISSION_WARNING="Claude will have unrestricted access to tools (file writes, shell commands, etc)."
    BACKEND_JQ_FLAGS=(-r)
    BACKEND_JQ_FILTER='select(.type == "result") | .result // empty'
    BACKEND_STDIN_PROMPT=true
    # shellcheck disable=SC2317,SC2329  # Invoked indirectly via resolve_backend
    build_backend_cmd() {
        local model="$1"
        BACKEND_CMD=(claude -p "$BACKEND_PERMISSION_FLAG" --output-format=stream-json --model "$model" --verbose)
    }
}

# shellcheck disable=SC2034  # Variables are set here and consumed in cmd_loop
backend_codex() {
    BACKEND_NAME="codex"
    BACKEND_CLI="codex"
    BACKEND_DEFAULT_MODEL="gpt-5.2-codex"
    BACKEND_PERMISSION_FLAG="--dangerously-bypass-approvals-and-sandbox"
    BACKEND_PERMISSION_WARNING="Codex will have unrestricted access to tools (file writes, shell commands, etc)."
    BACKEND_JQ_FLAGS=(-rs)
    BACKEND_JQ_FILTER='(map(select(.item.type == "agent_message")) | last | .item.text // null) // ([ .[] | select(.item.type == "command_execution" and .item.status == "completed") | "$ " + .item.command + "\n" + (.item.aggregated_output // "") ] | join("\n") | if . == "" then null else . end) // empty'
    BACKEND_STDIN_PROMPT=false
    # shellcheck disable=SC2317,SC2329  # Invoked indirectly via resolve_backend
    build_backend_cmd() {
        local model="$1"
        BACKEND_CMD=(codex exec "$BACKEND_PERMISSION_FLAG" --json --model "$model")
    }
}

# shellcheck disable=SC2034  # Variables are set here and consumed in cmd_loop
backend_copilot() {
    BACKEND_NAME="copilot"
    BACKEND_CLI="copilot"
    # Latest Claude Opus identifier exposed by Copilot CLI's model registry
    # (verify via `copilot model list`; bump when a newer Opus is published).
    BACKEND_DEFAULT_MODEL="claude-opus-4.7"
    # --allow-all bundles --allow-all-tools / --allow-all-paths / --allow-all-urls;
    # --allow-all-tools is required when running programmatically.
    BACKEND_PERMISSION_FLAG="--allow-all"
    BACKEND_PERMISSION_WARNING="Copilot will have unrestricted access to tools (file writes, shell commands, etc)."
    BACKEND_JQ_FLAGS=(-rs)
    # Prefer the final assistant.message text; fall back to a transcript of
    # successful tool.execution_complete events when no assistant.message was
    # emitted (mirrors the codex agent_message / command_execution fallback).
    BACKEND_JQ_FILTER='(map(select(.type == "assistant.message")) | last | .data.content // null) // ([ .[] | select(.type == "tool.execution_complete" and .data.success == true) | (.data.result.content // .data.result.detailedContent // "") ] | join("\n") | if . == "" then null else . end) // empty'
    BACKEND_STDIN_PROMPT=false
    # shellcheck disable=SC2317,SC2329  # Invoked indirectly via resolve_backend
    build_backend_cmd() {
        local model="$1"
        BACKEND_CMD=(copilot --output-format=json "$BACKEND_PERMISSION_FLAG" --model "$model" -p)
    }
}

resolve_backend() {
    local name="$1"
    local found=false
    for b in "${SUPPORTED_BACKENDS[@]}"; do
        if [[ "$b" == "$name" ]]; then
            found=true
            break
        fi
    done
    if ! $found; then
        echo "Error: unknown backend '$name'" >&2
        echo "Supported backends: ${SUPPORTED_BACKENDS[*]}" >&2
        exit 1
    fi
    "backend_${name}"
}

usage() {
    cat <<'EOF'
ralph — autonomous AI coding agent loop runner

Usage:
  ralph sandbox [--rebuild]
  ralph sandbox clean
  ralph <plan|build> [options]
  ralph init
  ralph clean
  ralph archive
  ralph version

Modes:
  sandbox        Enter a devcontainer shell for the current project
  sandbox clean  Remove the devcontainer for the current project
  plan           Analyse specs and source, create/update IMPLEMENTATION_PLAN.md
  build          Pick the next item, implement, test, commit, push
  init           Initialise workspace (PROGRESS.md, IMPLEMENTATION_PLAN.md, specs/)
  clean          Delete IMPLEMENTATION_PLAN.md and PROGRESS.md
  archive        Move IMPLEMENTATION_PLAN.md and PROGRESS.md to .ralph/<timestamp>/

Sandbox options:
      --rebuild        Rebuild the container image from scratch

Init options:
  -p, --prompts      Also copy prompt templates for local customisation

Options:
  -n, --iterations N   Max iterations (plan default: 3, build default: 50)
  -g, --goal TEXT      Goal to inject into the prompt template
  -m, --model MODEL    Model to use (default depends on backend)
  -b, --backend NAME   Backend to use (default: claude)
      --skip-push      Don't push after each iteration
      --dry-run        Print what would be executed without running
  -v, --verbose        Show backend commands, raw output, and exit codes
  -y, --yes            Skip the confirmation when running outside a sandbox
  -h, --help           Show this help message

Examples:
  ralph plan
  ralph plan -n 2
  ralph plan -g "Migrate to hexagonal architecture"
  ralph build -n 10 -m sonnet
  ralph build -b codex
  ralph build --iterations 5 --goal "Add PATCH endpoint"
  ralph sandbox
  ralph sandbox --rebuild
  ralph sandbox clean
  ralph archive
EOF
    exit 0
}

cmd_version() {
    echo "ralph $VERSION"
    exit 0
}

cmd_clean() {
    local found=false
    for file in "${ARTIFACTS[@]}"; do
        [[ "$file" == PROMPT_*.md ]] && continue
        if [[ -f "$file" ]]; then
            rm "$file"
            echo "Deleted: $file"
            found=true
        fi
    done
    $found || echo "Nothing to clean."
}

cmd_archive() {
    local found=false
    for file in "${ARTIFACTS[@]}"; do
        [[ "$file" == PROMPT_*.md ]] && continue
        if [[ -f "$file" ]]; then
            found=true
            break
        fi
    done

    if ! $found; then
        echo "Nothing to archive."
        return
    fi

    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)
    local dest="$ARCHIVE_DIR/$timestamp"
    mkdir -p "$dest"

    for file in "${ARTIFACTS[@]}"; do
        [[ "$file" == PROMPT_*.md ]] && continue
        if [[ -f "$file" ]]; then
            mv "$file" "$dest/"
            echo "Archived: $file -> $dest/$file"
        fi
    done
}

cmd_init() {
    local with_prompts=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--prompts) with_prompts=true; shift ;;
            *) echo "Error: unknown init option '$1'"; exit 1 ;;
        esac
    done

    local templates_dir="$CONFIG_DIR/templates"

    # Workspace artifacts
    if [[ -f "$templates_dir/PROGRESS.md" ]]; then
        scaffold "PROGRESS.md" "$templates_dir/PROGRESS.md"
    else
        echo "Warning: PROGRESS.md template not found at $templates_dir"
    fi

    if [[ -f "$templates_dir/IMPLEMENTATION_PLAN.md" ]]; then
        scaffold "IMPLEMENTATION_PLAN.md" "$templates_dir/IMPLEMENTATION_PLAN.md"
    else
        echo "Warning: IMPLEMENTATION_PLAN.md template not found at $templates_dir"
    fi

    if [[ -d "specs" ]]; then
        echo "Skipped: specs/ already exists"
    else
        mkdir -p "specs"
        echo "Created: specs/"
    fi

    # Bundled Claude Code skills (e.g. /commit) — scaffold into project-local .claude/skills/
    local skills_dir="$CONFIG_DIR/skills"
    if [[ -f "$skills_dir/commit/SKILL.md" ]]; then
        mkdir -p ".claude/skills/commit"
        scaffold ".claude/skills/commit/SKILL.md" "$skills_dir/commit/SKILL.md"
    else
        echo "Warning: commit skill not found at $skills_dir/commit/SKILL.md"
    fi

    # Add ralph artifacts to .gitignore
    if [[ ! -f ".gitignore" ]]; then
        touch .gitignore
        echo "Created: .gitignore"
    fi
    # Ensure file ends with a newline before appending
    [[ -s .gitignore && $(tail -c1 .gitignore) != "" ]] && echo >> .gitignore
    local ignore_entries=("IMPLEMENTATION_PLAN.md" "PROGRESS.md" ".ralph/" "PROMPT_plan.md" "PROMPT_build.md")
    for entry in "${ignore_entries[@]}"; do
        if ! grep -qxF "$entry" .gitignore; then
            echo "$entry" >> .gitignore
            echo "Added to .gitignore: $entry"
        fi
    done

    # Optional: copy prompt templates for local customisation
    if $with_prompts; then
        local prompts_dir="$CONFIG_DIR/prompts"
        if [[ ! -d "$prompts_dir" ]]; then
            echo "Error: ralph prompts not found at $prompts_dir"
            echo "Run the installer first: ./install.sh"
            exit 1
        fi
        for file in plan.md build.md; do
            scaffold "PROMPT_${file}" "$prompts_dir/$file"
        done
    fi
}

scaffold() {
    local target="$1"
    local source="$2"
    if [[ -f "$target" ]]; then
        echo "Skipped: $target already exists"
    else
        cp "$source" "$target"
        echo "Created: $target"
    fi
}

cmd_sandbox() {
    local rebuild=false

    case "${1:-}" in
        clean)     sandbox_clean; return ;;
        --rebuild) rebuild=true ;;
        "")        ;;
        *)         echo "Error: unknown sandbox option '$1'" >&2; exit 1 ;;
    esac

    if ! command -v devcontainer >/dev/null 2>&1; then
        echo "Error: 'devcontainer' CLI not found in PATH." >&2
        echo "Install it with: npm install -g @devcontainers/cli" >&2
        exit 1
    fi

    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Error: not inside a git repository." >&2
        exit 1
    fi

    # A submodule worktree's `.git` is a file containing a relative gitdir
    # pointer (e.g. `gitdir: ../../.git/modules/foo`). Bind-mounting the
    # workspace at /workspace in the container leaves the pointer unchanged,
    # so it resolves to a path that doesn't exist inside the container and
    # every subsequent git command — including devcontainer's own
    # postStartCommand — fails. Reject early with actionable guidance.
    if [[ -f .git && ! -d .git ]]; then
        echo "Error: workspace is a git submodule, which is not supported as a sandbox root." >&2
        echo "The submodule's .git pointer is relative to the parent repo and does not" >&2
        echo "resolve inside the container. Run ralph from the parent repository, or clone" >&2
        echo "the submodule's remote URL as a standalone repository." >&2
        exit 1
    fi

    local config="$CONFIG_DIR/container/devcontainer.json"
    if [[ ! -f "$config" ]]; then
        echo "Error: devcontainer config not found at $config" >&2
        echo "Run the installer first: ./install.sh" >&2
        exit 1
    fi

    mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.copilot"

    # Runtime mounts (conditional on host file existence)
    local mounts=()
    local ralph_bin
    ralph_bin="$(command -v ralph)"
    mounts+=("type=bind,source=$ralph_bin,target=/usr/local/bin/ralph")
    mounts+=("type=bind,source=$CONFIG_DIR,target=/home/node/.config/ralph")

    if [[ -d "$HOME/.ssh" ]]; then
        mounts+=("type=bind,source=$HOME/.ssh,target=/home/node/.ssh")
    fi
    if [[ -d "$HOME/.config/gh" ]]; then
        mounts+=("type=bind,source=$HOME/.config/gh,target=/home/node/.config/gh")
    fi
    if [[ -d "$HOME/.codex" ]]; then
        mounts+=("type=bind,source=$HOME/.codex,target=/home/node/.codex")
    fi
    if [[ -d "$HOME/.copilot" ]]; then
        mounts+=("type=bind,source=$HOME/.copilot,target=/home/node/.copilot")
    fi

    local ssh_env=()
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        mounts+=("type=bind,source=$SSH_AUTH_SOCK,target=/tmp/ssh-agent.sock")
        ssh_env=("--remote-env" "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
    fi

    # GPG agent forwarding — lets the build loop sign commits with the host key
    # without copying any private key material into the container. The host
    # gpg-agent holds the secret; the container's gpg reaches it over the
    # forwarded socket and reads the mounted public keyring. Prefer the agent's
    # restricted "extra" socket, falling back to the standard socket.
    if command -v gpgconf >/dev/null 2>&1; then
        local gpg_sock gpg_home
        gpg_sock="$(gpgconf --list-dirs agent-extra-socket 2>/dev/null)"
        [[ -S "$gpg_sock" ]] || gpg_sock="$(gpgconf --list-dirs agent-socket 2>/dev/null)"
        if [[ -S "$gpg_sock" ]]; then
            mounts+=("type=bind,source=$gpg_sock,target=/home/node/.gnupg/S.gpg-agent")
            gpg_home="$(gpgconf --list-dirs homedir 2>/dev/null)"
            if [[ -f "$gpg_home/pubring.kbx" ]]; then
                # The devcontainer CLI's --mount only accepts type/source/target
                # (and optional external); it rejects a `readonly` key, unlike
                # the static mounts in devcontainer.json.
                mounts+=("type=bind,source=$gpg_home/pubring.kbx,target=/home/node/.gnupg/pubring.kbx")
            fi
        fi
    fi
    if [[ -n "${OPENAI_API_KEY:-}" ]]; then
        ssh_env+=("--remote-env" "OPENAI_API_KEY=$OPENAI_API_KEY")
    fi
    if [[ -n "${OPENROUTER_API_KEY:-}" ]]; then
        ssh_env+=("--remote-env" "OPENROUTER_API_KEY=$OPENROUTER_API_KEY")
    fi
    if [[ -n "${ANTHROPIC_BASE_URL:-}" ]]; then
        ssh_env+=("--remote-env" "ANTHROPIC_BASE_URL=$ANTHROPIC_BASE_URL")
    fi
    if [[ -n "${ANTHROPIC_AUTH_TOKEN:-}" ]]; then
        ssh_env+=("--remote-env" "ANTHROPIC_AUTH_TOKEN=$ANTHROPIC_AUTH_TOKEN")
    fi
    if [[ -n "${ANTHROPIC_API_KEY+set}" ]]; then
        ssh_env+=("--remote-env" "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}")
    fi
    if [[ -n "${GH_TOKEN:-}" ]]; then
        ssh_env+=("--remote-env" "GH_TOKEN=$GH_TOKEN")
    fi
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        ssh_env+=("--remote-env" "GITHUB_TOKEN=$GITHUB_TOKEN")
    fi

    # Shell history volume (deterministic per workspace)
    local workspace_hash
    if command -v md5sum &>/dev/null; then
        workspace_hash=$(echo -n "$PWD" | md5sum | cut -c1-12)
    elif command -v md5 &>/dev/null; then
        workspace_hash=$(echo -n "$PWD" | md5 | cut -c1-12)
    else
        echo "Error: no md5sum or md5 command found — install coreutils" >&2
        return 1
    fi
    mounts+=("type=volume,source=ralph-history-${workspace_hash},target=/commandhistory")

    local mount_flags=()
    for mount in "${mounts[@]}"; do
        mount_flags+=("--mount" "$mount")
    done

    # Start or reuse container
    local up_args=(
        "--workspace-folder" "$PWD"
        "--config" "$config"
        "${mount_flags[@]}"
        ${ssh_env[@]+"${ssh_env[@]}"}
    )
    if $rebuild; then
        up_args+=("--remove-existing-container" "--build-no-cache")
    fi

    echo "Starting sandbox..."
    devcontainer up "${up_args[@]}"

    # Drop into shell
    devcontainer exec \
        --workspace-folder "$PWD" \
        --config "$config" \
        ${ssh_env[@]+"${ssh_env[@]}"} \
        zsh
}

sandbox_clean() {
    if ! command -v docker >/dev/null 2>&1; then
        echo "Error: 'docker' not found in PATH." >&2
        exit 1
    fi

    local container_id
    container_id=$(docker ps -a --filter "label=devcontainer.local_folder=$PWD" --format '{{.ID}}')

    if [[ -z "$container_id" ]]; then
        echo "No sandbox container found for $PWD"
        return
    fi

    docker rm -f "$container_id" >/dev/null
    echo "Removed sandbox container for $PWD"
}

# Resolve which prompt file to use.
# Priority: project-local PROMPT_<mode>.md > installed default
resolve_prompt() {
    local mode="$1"
    local local_file="PROMPT_${mode}.md"
    local default_file="$CONFIG_DIR/prompts/${mode}.md"

    if [[ -f "$local_file" ]]; then
        echo "$local_file"
    elif [[ -f "$default_file" ]]; then
        echo "$default_file"
    else
        echo "Error: no prompt found for mode '$mode'" >&2
        echo "Looked for: $local_file, $default_file" >&2
        echo "Run 'ralph init' to scaffold local prompts, or reinstall with ./install.sh" >&2
        exit 1
    fi
}

# Verify workspace artifacts produced by 'ralph init' are present.
# Plan needs IMPLEMENTATION_PLAN.md (the template the agent fills in).
# Build needs both IMPLEMENTATION_PLAN.md and PROGRESS.md.
require_init_artifacts() {
    local mode="$1"
    local required=()

    case "$mode" in
        plan)  required=(IMPLEMENTATION_PLAN.md) ;;
        build) required=(IMPLEMENTATION_PLAN.md PROGRESS.md) ;;
    esac

    local missing=()
    for f in "${required[@]}"; do
        [[ -f "$f" ]] || missing+=("$f")
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Error: missing workspace artifacts required for '$mode': ${missing[*]}" >&2
        echo "Run 'ralph init' to scaffold them before running 'ralph $mode'." >&2
        exit 1
    fi
}

# Calculate build iterations from IMPLEMENTATION_PLAN.md.
# Counts incomplete items (- [ ]) and adds 20% headroom (rounded up, minimum 1).
# Caller must ensure IMPLEMENTATION_PLAN.md exists (see require_init_artifacts).
calculate_build_iterations() {
    local count
    count=$(grep -c '^\- \[ \]' "IMPLEMENTATION_PLAN.md" || true)

    if [[ "$count" -eq 0 ]]; then
        echo "Error: no incomplete items in IMPLEMENTATION_PLAN.md. Run 'ralph plan' first." >&2
        exit 1
    fi

    # 20% headroom, rounded up: ceil(count * 1.2)
    echo $(( (count * 6 + 4) / 5 ))
}

truncate_line() {
    local text="$1" max="$2"
    if [[ ${#text} -gt $max ]]; then
        echo "${text:0:$((max - 3))}..."
    else
        echo "$text"
    fi
}

cmd_loop() {
    local mode="$1"
    shift

    # Parse flags
    local max_iterations=""
    local goal=""
    local model=""
    local backend=""
    local skip_push=false
    local dry_run=false
    local verbose=false
    local assume_yes=false

    ARGS=$(getopt -o n:g:m:b:vyh --long iterations:,goal:,model:,backend:,skip-push,dry-run,verbose,yes,help -n 'ralph' -- "$@")
    eval set -- "$ARGS"

    while true; do
        case "$1" in
            -n|--iterations) max_iterations="$2"; shift 2 ;;
            -g|--goal)       goal="$2";           shift 2 ;;
            -m|--model)      model="$2";          shift 2 ;;
            -b|--backend)    backend="$2";        shift 2 ;;
            --skip-push)     skip_push=true;      shift ;;
            --dry-run)       dry_run=true;        shift ;;
            -v|--verbose)    verbose=true;        shift ;;
            -y|--yes)        assume_yes=true;     shift ;;
            -h|--help)       usage ;;
            --)              shift; break ;;
        esac
    done

    # Validate explicit -n value before any state-dependent work, so syntax
    # errors fire regardless of workspace state.
    local hard_override=false
    if [[ -n "$max_iterations" ]]; then
        if [[ ! "$max_iterations" =~ ^[1-9][0-9]*$ ]]; then
            echo "Error: iterations must be a positive integer, got '$max_iterations'" >&2
            exit 1
        fi
        hard_override=true
    fi

    # Fail fast if 'ralph init' hasn't been run — checked before any backend
    # resolution, CLI lookup, or git work so the user gets immediate feedback.
    require_init_artifacts "$mode"

    # Resolve backend: CLI flag > default
    backend="${backend:-claude}"
    resolve_backend "$backend"

    # Apply backend default model if -m not explicitly passed
    if [[ -z "$model" ]]; then
        model="$BACKEND_DEFAULT_MODEL"
    fi

    # Resolve iteration count from defaults/heuristics when -n wasn't passed.
    if ! $hard_override; then
        case "$mode" in
            plan)  max_iterations=$PLAN_DEFAULT_CAP ;;
            build) max_iterations=$(calculate_build_iterations) ;;
        esac
    fi

    # Verify backend CLI is available (not needed for dry-run)
    if ! $dry_run && ! command -v "$BACKEND_CLI" >/dev/null 2>&1; then
        echo "Error: '$BACKEND_CLI' CLI not found in PATH." >&2
        exit 1
    fi

    # Verify git is available and we're inside a repo
    if ! command -v git >/dev/null 2>&1; then
        echo "Error: 'git' not found in PATH." >&2
        exit 1
    fi
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Error: not inside a git repository. Run 'git init' first." >&2
        exit 1
    fi

    local prompt_file
    prompt_file=$(resolve_prompt "$mode")

    local current_branch
    current_branch=$(git branch --show-current)

    # Build the backend command array now that model is resolved
    build_backend_cmd "$model"

    local line_width=120
    local bar
    bar=$(printf '━%.0s' $(seq 1 "$line_width"))

    echo "$bar"
    echo "Mode:    $mode"
    echo "Backend: $BACKEND_NAME"
    truncate_line "Prompt:  $prompt_file" "$line_width"
    echo "Branch:  $current_branch"
    echo "Model:   $model"
    echo "Max:     $max_iterations iterations"
    [[ -n "$goal" ]] && truncate_line "Goal:    $goal" "$line_width"
    echo "$bar"

    # Permission handling:
    #   Backends run non-interactively and cannot prompt for tool approval,
    #   so the backend's permission flag is always required.
    #   Inside a devcontainer, network isolation provides additional safety.
    if [[ "${DEVCONTAINER:-false}" != "true" ]]; then
        truncate_line "⚠️  WARNING: Running with $BACKEND_PERMISSION_FLAG outside a container." "$line_width" >&2
        truncate_line "⚠️  $BACKEND_PERMISSION_WARNING" "$line_width" >&2
        truncate_line "⚠️  For safer execution, use the provided devcontainer." "$line_width" >&2
        echo "" >&2

        # Interactive opt-out. Only prompt when attached to a terminal and not
        # auto-confirmed; non-interactive callers (CI, cron, /loop, tests)
        # proceed as before. Dry-run executes nothing dangerous, so never prompts.
        if ! $assume_yes && ! $dry_run && [[ -t 0 ]]; then
            printf 'Continue anyway? [y/N] ' >&2
            local reply=''
            read -r reply
            if [[ ! "$reply" =~ ^[Yy] ]]; then
                echo 'Aborted.' >&2
                exit 1
            fi
        fi
    fi

    local iteration=0
    local consecutive_noops=0

    # Clean exit on interrupt signals
    trap 'echo -e "\nInterrupted at iteration $iteration / $max_iterations" >&2; exit 130' SIGINT SIGTERM

    while [[ $iteration -lt $max_iterations ]]; do
        iteration=$((iteration + 1))
        local iter_label=" ITERATION $iteration / $max_iterations "
        local pad_total=$((line_width - ${#iter_label}))
        local pad_left=$((pad_total / 2))
        local pad_right=$((pad_total - pad_left))
        printf '\n%s%s%s\n\n' \
            "$(printf '%*s' "$pad_left" '' | tr ' ' '=')" \
            "$iter_label" \
            "$(printf '%*s' "$pad_right" '' | tr ' ' '=')"

        # Snapshot HEAD to detect noops
        local head_before
        head_before=$(git rev-parse HEAD)

        # Inject {{GOAL}} into prompt using bash substitution
        local prompt
        prompt=$(<"$prompt_file")
        prompt="${prompt//\{\{GOAL\}\}/${goal:-No specific goal provided}}"

        if $dry_run; then
            if [[ "$BACKEND_STDIN_PROMPT" == "true" ]]; then
                echo "[dry-run] Would run: ${BACKEND_CMD[*]}"
            else
                echo "[dry-run] Would run: ${BACKEND_CMD[*]} <prompt>"
            fi
            echo "[dry-run] Prompt content ($prompt_file with goal substituted):"
            echo "$prompt"
        else
            # Verbose: print backend command before execution
            if $verbose; then
                if [[ "$BACKEND_STDIN_PROMPT" == "true" ]]; then
                    echo "[verbose] Backend command: ${BACKEND_CMD[*]}" >&2
                else
                    local truncated_prompt="$prompt"
                    if [[ ${#truncated_prompt} -gt 200 ]]; then
                        truncated_prompt="${truncated_prompt:0:200}..."
                    fi
                    echo "[verbose] Backend command: ${BACKEND_CMD[*]} $truncated_prompt" >&2
                fi
            fi

            # Run backend command separately, capturing stdout while preserving stderr
            local backend_output=""
            local backend_exit=0
            if [[ "$BACKEND_STDIN_PROMPT" == "true" ]]; then
                backend_output=$(echo "$prompt" | "${BACKEND_CMD[@]}" 2> >(
                    if $verbose; then
                        echo "[verbose] === Backend stderr ===" >&2
                        cat >&2
                        echo "[verbose] === End backend stderr ===" >&2
                    else
                        cat >&2
                    fi
                )) || backend_exit=$?
            else
                backend_output=$("${BACKEND_CMD[@]}" "$prompt" 2> >(
                    if $verbose; then
                        echo "[verbose] === Backend stderr ===" >&2
                        cat >&2
                        echo "[verbose] === End backend stderr ===" >&2
                    else
                        cat >&2
                    fi
                )) || backend_exit=$?
            fi

            if [[ $backend_exit -ne 0 ]]; then
                echo "Error: backend command failed on iteration $iteration (exit code $backend_exit)" >&2
                echo "Hint: re-run with --dry-run to inspect the prompt, or --verbose for full diagnostics" >&2
                exit "$backend_exit"
            fi

            # Verbose: show raw backend output before jq
            if $verbose; then
                echo "[verbose] Raw backend output:" >&2
                echo "$backend_output" >&2
            fi

            # Run jq separately on captured output
            local jq_output=""
            local jq_exit=0
            jq_output=$(echo "$backend_output" | jq "${BACKEND_JQ_FLAGS[@]}" "$BACKEND_JQ_FILTER") || jq_exit=$?

            if [[ $jq_exit -ne 0 ]]; then
                echo "Error: jq parse failure on iteration $iteration (exit code $jq_exit)" >&2
                echo "Hint: re-run with --verbose to see raw backend output before jq processing" >&2
                exit "$jq_exit"
            fi

            # Verbose: show exit codes
            if $verbose; then
                echo "[verbose] Exit codes — backend: $backend_exit, jq: $jq_exit" >&2
            fi

            # Print jq output (unchanged behaviour)
            echo "$jq_output"
        fi

        # Push changes after each iteration
        if $dry_run; then
            echo "[dry-run] Would run: git push origin $current_branch"
        elif ! $skip_push; then
            local push_output
            if ! push_output=$(git push origin "$current_branch" 2>&1); then
                if echo "$push_output" | grep -q "has no upstream branch"; then
                    echo "No upstream branch found. Setting upstream..."
                    git push -u origin "$current_branch"
                else
                    echo "Push failed:" >&2
                    echo "$push_output" >&2
                    exit 1
                fi
            elif $verbose; then
                echo "[verbose] Push output:" >&2
                echo "$push_output" >&2
            fi
        fi

        # Noop detection: exit early after 2 consecutive noops (build mode only, unless -n was passed).
        # Plan mode doesn't produce commits (IMPLEMENTATION_PLAN.md is gitignored), so HEAD never advances.
        if [[ "$mode" == "build" ]] && ! $hard_override && ! $dry_run; then
            local head_after
            head_after=$(git rev-parse HEAD)
            if [[ "$head_before" == "$head_after" ]]; then
                consecutive_noops=$((consecutive_noops + 1))
                if [[ $consecutive_noops -ge 2 ]]; then
                    echo -e "\nNo changes detected for 2 consecutive iterations — exiting early."
                    break
                fi
            else
                consecutive_noops=0
            fi
        fi
    done

    echo -e "\nCompleted $iteration iterations."
}

# Main dispatch
case "${1:-}" in
    sandbox)    shift; cmd_sandbox "$@" ;;
    plan|build) cmd_loop "$@" ;;
    init)       shift; cmd_init "$@" ;;
    clean)      cmd_clean ;;
    archive)    cmd_archive ;;
    version)    cmd_version ;;
    -h|--help)  usage ;;
    "")         usage ;;
    *)          echo "Error: unknown command '$1'"; exit 1 ;;
esac
